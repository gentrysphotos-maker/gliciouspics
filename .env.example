# ───────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and replace each REPLACE_ME with a real value.
# Never commit .env. The placeholders here intentionally use REPLACE_ME
# so it's obvious if you forgot to swap one out.
# ───────────────────────────────────────────────────────────────────────

# Stripe — test mode for development, switch to live keys at launch.
# Source: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=REPLACE_ME_sk_test_xxx
STRIPE_PUBLISHABLE_KEY=REPLACE_ME_pk_test_xxx

# Stripe webhook signing secret.
#   - Local dev:  run `stripe listen --forward-to localhost:8080/api/webhooks/stripe`
#                 and paste the whsec_... it prints.
#   - Local mock: set to `whsec_placeholder` to bypass signature checks
#                 for scratch/test_webhook.js (only works when NODE_ENV != production).
#   - Production: get from Stripe Dashboard → Developers → Webhooks → your endpoint.
STRIPE_WEBHOOK_SECRET=REPLACE_ME_whsec_xxx

# Resend transactional email (optional in dev — emails save to temp_emails/
# locally if not set). Source: https://resend.com/api-keys
RESEND_API_KEY=REPLACE_ME_re_xxx
OWNER_EMAIL=gentrysphotos@example.com

# Prodigi Print API — sandbox key for testing, live key for production.
#   - Sign up at https://dashboard.prodigi.com (this creates BOTH a Live and
#     a Sandbox account automatically).
#   - Get your sandbox API key from https://sandbox-beta-dashboard.pwinty.com
#     (Settings / API). Sandbox keys are opaque strings — no fixed prefix.
#   - Sandbox orders are never produced or charged.
PRODIGI_API_KEY=REPLACE_ME_sandbox_key

# Prodigi API base URL.
#   - Sandbox (default):  https://api.sandbox.prodigi.com/v4.0
#   - Production:         https://api.prodigi.com/v4.0
# Defaults to sandbox if unset.
PRODIGI_API_URL=https://api.sandbox.prodigi.com/v4.0

# Express server port. Railway injects PORT automatically in production;
# this is only used for local dev.
PORT=8080

# NODE_ENV controls dev-only behavior (e.g. saving order JSON to orders/
# on disk, bypassing webhook signature with whsec_placeholder).
# Railway sets this to "production" automatically — leave unset locally.
# NODE_ENV=production
